---
import Base from '../layouts/Base.astro';

import Hero from '../components/sections/Hero.astro';
import ValueProps from '../components/sections/ValueProps.astro';
import UseCases from '../components/sections/UseCases.astro';
import CloudFeatures from '../components/sections/CloudFeatures.astro';
import OssFeatures from '../components/sections/OssFeatures.astro';
import QuickStart from '../components/sections/QuickStart.astro';
import Benchmarks from '../components/sections/Benchmarks.astro';
import DashboardPreview from '../components/sections/DashboardPreview.astro';
import PlansPreview from '../components/sections/PlansPreview.astro';
import ProductionSecurity from '../components/sections/ProductionSecurity.astro';
import Documentation from '../components/sections/Documentation.astro';
import BuiltonOpenSource from '../components/sections/BuiltonOpenSource.astro';
---

<Base title="MCP Hangar -- Control Plane for AI Agents" description="The essential control plane for Model Context Protocol. Cloud managed or open-source self-hosted." path="/">
    <!-- Background effects -->
    <div class="fixed inset-0 z-[-1]">
        <div class="absolute inset-0 bg-zinc-950"/>
        <div
            class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-sky-900/20 via-zinc-950 to-zinc-950"/>
        <div
            class="fixed inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E')] opacity-[0.03]"/>
    </div>

    <main>
        <Hero />
        <ValueProps />
        <UseCases />
        <CloudFeatures />
        <OssFeatures />
        <QuickStart />
        <Benchmarks />
        <DashboardPreview />
        <PlansPreview />
        <ProductionSecurity />
        <Documentation />
        <BuiltonOpenSource />
    </main>
</Base>
