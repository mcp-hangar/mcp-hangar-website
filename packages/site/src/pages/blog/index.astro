---
import Base from '../../layouts/Base.astro';
import BlogByline from '../../components/BlogByline.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Blog | MCP Hangar" description="Latest news and updates from the MCP Hangar team." path="/blog">
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-zinc-50 mb-8">Blog</h1>
    
    <div class="space-y-8">
      {sortedPosts.map(post => (
        <article class="bg-zinc-900/50 p-6 rounded-xl border border-zinc-800/50 hover:border-zinc-700/50 transition-colors">
          <h2 class="text-2xl font-semibold mb-2">
            <a href={`/blog/${post.id}`} class="text-zinc-100 hover:text-emerald-400 transition-colors">
              {post.data.title}
            </a>
          </h2>
          <div class="mb-4">
            <BlogByline date={post.data.date} author={post.data.author} />
          </div>
          <p class="text-zinc-400">{post.data.description}</p>
        </article>
      ))}
    </div>
  </main>
</Base>
