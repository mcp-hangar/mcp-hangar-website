---
import Base from '../../layouts/Base.astro';
import BlogByline from '../../components/BlogByline.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base 
  title={`${post.data.title} | Blog | MCP Hangar`} 
  description={post.data.description} 
  path={`/blog/${post.id}`}
>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose prose-invert prose-emerald max-w-none">
      <h1 class="text-4xl font-bold text-zinc-50 mb-4">{post.data.title}</h1>
      <div class="mb-8 pb-8 border-b border-zinc-800/50">
        <BlogByline date={post.data.date} author={post.data.author} />
      </div>
      
      <div class="mt-8">
        <Content />
      </div>
    </article>
  </main>
</Base>
