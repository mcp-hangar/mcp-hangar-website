---
interface Props {
    pulse?: boolean;
    class?: string;
}
const { pulse = true, class: className = "" } = Astro.props;
---

<div
    class={`inline-flex items-center gap-2 px-3 py-1 rounded-full bg-sky-500/10 border border-sky-500/20 text-sky-400 text-sm cursor-default hover:bg-sky-500/15 transition-all ${className}`}
    role="status"
>
    {pulse && <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse" aria-hidden="true"/>}
    <slot />
</div>
