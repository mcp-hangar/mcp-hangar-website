---
interface Props {
    number: number;
    title: string;
    description: string;
    isLast?: boolean;
}

const { number, title, description, isLast = false } = Astro.props;
---

<li class="relative flex gap-6">
    <!-- Left column: number badge + connector line -->
    <div class="flex flex-col items-center">
        <div
            class="relative z-10 flex items-center justify-center w-10 h-10 rounded-full bg-emerald-500/15 border border-emerald-500/30 text-emerald-400 font-bold text-sm shrink-0 shadow-lg shadow-emerald-500/5"
        >
            {number}
        </div>
        {!isLast && (
            <div class="w-px flex-1 bg-gradient-to-b from-emerald-500/30 to-emerald-500/5 mt-3"></div>
        )}
    </div>

    <!-- Right column: content -->
    <div class={`${isLast ? 'pb-0' : 'pb-12'} flex-1 min-w-0`}>
        <h3 class="text-lg font-semibold text-zinc-100 mb-2 mt-1.5">
            {title}
        </h3>
        <p class="text-zinc-400 mb-4 leading-relaxed">
            {description}
        </p>
        <div class="mt-4">
            <slot />
        </div>
    </div>
</li>
