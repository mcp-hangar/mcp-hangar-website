---
/**
 * Structured navigation for the documentation sidebar.
 * Sections and their order are derived from the `oss` docs collection via
 * `buildDocsNav`, so new docs appear automatically and never drift from the
 * prev/next pager (which is built from the same source).
 *
 * Sections are collapsible (native <details>): the section containing the
 * current page is expanded, the rest are collapsed, so a ~75-link tree renders
 * as a short list of headers with only the relevant branch open. No client JS —
 * the open section is decided server-side from the active path.
 */
import { getCollection } from 'astro:content';
import { buildDocsNav } from '../docsNav';

interface Props {
  mobile?: boolean;
}

const docs = await getCollection('oss');
const { sections } = buildDocsNav(docs);

const { mobile = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '');

// Which section owns the current page? That one starts expanded; if none does
// (docs index, or a page absent from the nav) the first section opens instead
// so the sidebar is never a wall of collapsed headers with nothing showing.
const activeIndex = sections.findIndex((section) =>
  section.links.some((link) => link.href.replace(/\/$/, '') === currentPath)
);
---

<aside class:list={["docs-sidebar", mobile ? "w-full" : "w-64 shrink-0 hidden lg:block"]}>
  <nav class:list={[
    "overflow-y-auto pb-8",
    mobile ? "" : "sticky top-20 max-h-[calc(100vh-6rem)] pr-4"
  ]} aria-label="Documentation">
    <a
      href="/docs/"
      class:list={[
        "block text-sm font-semibold mb-4 transition-colors duration-200",
        currentPath === '/docs' ? 'text-emerald-400' : 'text-zinc-200 hover:text-emerald-400'
      ]}
    >
      Documentation
    </a>

    {sections.map((section, i) => {
      const isOpen = i === activeIndex || (activeIndex === -1 && i === 0);
      return (
        <details open={isOpen} class="docs-section mb-1">
          <summary class="flex items-center justify-between cursor-pointer select-none text-xs font-semibold text-zinc-500 uppercase tracking-wider py-1.5 px-2 rounded hover:text-zinc-300 hover:bg-zinc-800/40 transition-colors">
            <span>{section.title}</span>
            <svg class="chevron w-3 h-3 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </summary>
          <ul class="space-y-0.5 mt-1 mb-3">
            {section.links.map((link) => {
              const linkPath = link.href.replace(/\/$/, '');
              const isActive = currentPath === linkPath;
              return (
                <li>
                  <a
                    href={link.href}
                    aria-current={isActive ? 'page' : undefined}
                    class:list={[
                      "block text-[13px] py-1 px-2 rounded transition-colors duration-200",
                      isActive
                        ? 'text-emerald-400 bg-emerald-400/10 font-medium'
                        : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/50'
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </details>
      );
    })}
  </nav>
</aside>

<style>
  /* Native disclosure: hide the default marker, rotate our chevron when open. */
  .docs-section > summary {
    list-style: none;
  }
  .docs-section > summary::-webkit-details-marker {
    display: none;
  }
  .docs-section[open] > summary .chevron {
    transform: rotate(90deg);
  }
</style>
