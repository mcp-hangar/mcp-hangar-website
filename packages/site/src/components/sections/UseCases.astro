---
import Feature from "../Feature.astro";
import AuditIcon from "../icons/AuditIcon.astro";
import ShieldCheckIcon from "../icons/ShieldCheckIcon.astro";
import LockIcon from "../icons/LockIcon.astro";
---
<div class="max-w-6xl mx-auto px-6 pb-20">
                    <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wider mb-6 text-center">
                        Built for real problems
                    </h2>
                    <div class="stagger-grid grid grid-cols-1 md:grid-cols-3 gap-4">
                        <Feature 
                            title="Access control per team"
                            description="Team A gets read access to the knowledge base MCP. Team B is blocked. Enforced at the proxy level — no changes to your MCP servers required."
                            accentColor="emerald"
                        >
    <ShieldCheckIcon slot="icon" />
</Feature>
                        <Feature 
                            title="Usage you can explain"
                            description="Your production database MCP was called 4,200 times last week. Here is who called it, from which system, and with what arguments."
                            accentColor="sky"
                        >
    <AuditIcon slot="icon" />
</Feature>
                        <div class="group p-6 rounded-2xl bg-zinc-900/30 border border-zinc-800/50 hover:border-amber-500/20 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-amber-500/5">
                            <div class="w-10 h-10 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 mb-4 group-hover:scale-110 group-hover:bg-amber-500/20 transition-all duration-300">
                                <LockIcon/>
                            </div>
                            <h3 class="font-semibold text-zinc-100 mb-2 group-hover:text-amber-50 transition-colors duration-300">
                                Controlled write rollouts
                            </h3>
                            <p class="text-sm text-zinc-500 leading-relaxed group-hover:text-zinc-400 transition-colors duration-300">
                                Your CI pipeline wants write access to the repo MCP. Review the request, approve it, monitor the rollout. Roll back in one config change.
                            </p>
                        </div>
                    </div>
                </div>
