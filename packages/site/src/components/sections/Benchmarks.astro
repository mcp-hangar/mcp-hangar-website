---

---
<div class="max-w-6xl mx-auto px-6 pb-32">
                    <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wider mb-6">
                        Benchmarks
                    </h2>
                    <div class="bg-zinc-900/30 border border-zinc-800/50 rounded-2xl overflow-hidden">
                        <table class="w-full">
                            <thead>
                            <tr class="border-b border-zinc-800/50">
                                <th class="text-left text-sm font-semibold text-zinc-300 px-6 py-4">Scenario</th>
                                <th class="text-left text-sm font-semibold text-zinc-300 px-6 py-4">Time</th>
                                <th class="text-left text-sm font-semibold text-zinc-300 px-6 py-4">Notes</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr class="border-b border-zinc-800/30">
                                <td class="px-6 py-4 text-zinc-400">Full proxy path (p50 / p99)</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">0.21ms / 0.24ms</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">20x under 5ms target</td>
                            </tr>
                            <tr class="border-b border-zinc-800/30">
                                <td class="px-6 py-4 text-zinc-400">Policy engine (1,000 policies)</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">6.5&micro;s</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">100%</td>
                            </tr>
                            <tr class="border-b border-zinc-800/30">
                                <td class="px-6 py-4 text-zinc-400">Event buffer with WAL persist</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">158&micro;s</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">100%</td>
                            </tr>
                            <tr class="border-b border-zinc-800/30">
                                <td class="px-6 py-4 text-zinc-400">15 tools, 2 servers (parallel)</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">380ms</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">100%</td>
                            </tr>
                            <tr>
                                <td class="px-6 py-4 text-zinc-400">Domain event mapping</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">5.3&micro;s</td>
                                <td class="px-6 py-4 text-emerald-400 font-mono">100%</td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-sm text-zinc-500 mt-4">
                        Measured via pytest-benchmark (Python) and Go benchmark suite.
                        Full results in the{" "}
                        <a href="/docs/reference/benchmarks" class="text-emerald-400 hover:text-emerald-300 underline underline-offset-2 transition-colors">
                            v1.2.2 benchmark report
                        </a>.
                    </p>
                </div>
