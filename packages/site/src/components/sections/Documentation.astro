---
import { getCollection } from "astro:content";
import RocketIcon from "../icons/RocketIcon.astro";
import BookOpenIcon from "../icons/BookOpenIcon.astro";
import FileTextIcon from "../icons/FileTextIcon.astro";
import { countCookbookRecipes } from "../../docsNav";

const recipeCount = countCookbookRecipes(await getCollection("oss"));
---

<section class="max-w-6xl mx-auto px-6 pb-32">
    <div class="text-center mb-8">
        <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wider mb-3">
            Documentation
        </h2>
        <p class="text-xl text-zinc-300">
            Dive deeper into Hangar
        </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a
            href="/docs/getting-started/quickstart"
            class="group flex items-start gap-4 p-5 rounded-xl bg-zinc-900/30 border border-zinc-800/50 hover:border-emerald-500/20 hover:bg-zinc-900/50 transition-all duration-300"
        >
            <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 shrink-0">
                <RocketIcon/>
            </div>
            <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-zinc-100 mb-1 group-hover:text-emerald-300 transition-colors">Getting Started</h3>
                <p class="text-sm text-zinc-500">Install and make your first call in 2 minutes</p>
            </div>
            <span class="text-zinc-600 group-hover:text-emerald-400 group-hover:translate-x-0.5 transition-all mt-1">&rarr;</span>
        </a>
        <a
            href="/docs/cookbook/index"
            class="group flex items-start gap-4 p-5 rounded-xl bg-zinc-900/30 border border-zinc-800/50 hover:border-emerald-500/20 hover:bg-zinc-900/50 transition-all duration-300"
        >
            <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 shrink-0">
                <BookOpenIcon/>
            </div>
            <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-zinc-100 mb-1 group-hover:text-emerald-300 transition-colors">Cookbook</h3>
                <p class="text-sm text-zinc-500">{recipeCount} production recipes, copy-paste ready</p>
            </div>
            <span class="text-zinc-600 group-hover:text-emerald-400 group-hover:translate-x-0.5 transition-all mt-1">&rarr;</span>
        </a>
        <a
            href="/docs/reference/configuration"
            class="group flex items-start gap-4 p-5 rounded-xl bg-zinc-900/30 border border-zinc-800/50 hover:border-emerald-500/20 hover:bg-zinc-900/50 transition-all duration-300"
        >
            <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 shrink-0">
                <FileTextIcon/>
            </div>
            <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-zinc-100 mb-1 group-hover:text-emerald-300 transition-colors">Reference</h3>
                <p class="text-sm text-zinc-500">Configuration, CLI, REST API, MCP tools</p>
            </div>
            <span class="text-zinc-600 group-hover:text-emerald-400 group-hover:translate-x-0.5 transition-all mt-1">&rarr;</span>
        </a>
    </div>
</section>
