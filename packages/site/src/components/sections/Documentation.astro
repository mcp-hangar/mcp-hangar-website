---
import RocketIcon from "../icons/RocketIcon.astro";
import BookOpenIcon from "../icons/BookOpenIcon.astro";
import FileTextIcon from "../icons/FileTextIcon.astro";
---
<div class="max-w-6xl mx-auto px-6 pb-32">
                    <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wider mb-6">
                        Documentation
                    </h2>
                    <p class="text-zinc-400 mb-8 max-w-2xl">
                        Everything you need to get started with the open-source agent.
                    </p>
                    <div class="stagger-grid grid grid-cols-1 md:grid-cols-3 gap-4">
                        <a
                            href="/docs/oss/getting-started/quickstart"
                            class="group p-6 rounded-2xl bg-zinc-900/30 border border-zinc-800/50 hover:border-emerald-500/20 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1"
                        >
                            <div
                                class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 mb-4">
                                <RocketIcon/>
                            </div>
                            <h3 class="font-semibold text-zinc-100 mb-2">Getting Started</h3>
                            <p class="text-sm text-zinc-400">Install the agent and make your first parallel call</p>
                        </a>
                        <a
                            href="/docs/oss/cookbook/"
                            class="group p-6 rounded-2xl bg-zinc-900/30 border border-zinc-800/50 hover:border-emerald-500/20 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1"
                        >
                            <div
                                class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 mb-4">
                                <BookOpenIcon/>
                            </div>
                            <h3 class="font-semibold text-zinc-100 mb-2">Cookbook</h3>
                            <p class="text-sm text-zinc-400">13 recipes from zero to production</p>
                        </a>
                        <a
                            href="/docs/oss/reference/configuration"
                            class="group p-6 rounded-2xl bg-zinc-900/30 border border-zinc-800/50 hover:border-emerald-500/20 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1"
                        >
                            <div
                                class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 mb-4">
                                <FileTextIcon/>
                            </div>
                            <h3 class="font-semibold text-zinc-100 mb-2">Reference</h3>
                            <p class="text-sm text-zinc-400">Configuration, CLI, REST API, MCP tools</p>
                        </a>
                    </div>
                </div>
