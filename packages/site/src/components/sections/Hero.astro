---
import Badge from "../Badge.astro";
import Button from "../Button.astro";
import GithubIcon from "../icons/GithubIcon.astro";
import { LINKS, VERSION_TAG } from "../../config";
---

<section class="max-w-6xl mx-auto px-6 pt-24 pb-32">
  <div class="max-w-3xl mx-auto text-center">
    <Badge class="animate-fade-in mb-8">{VERSION_TAG} — Open Source — MIT License</Badge>

    <h1 class="animate-slide-up text-5xl md:text-7xl font-bold tracking-tight leading-[1.1] mb-6">
      The policy enforcement
      <br/>
      <span class="bg-gradient-to-r from-emerald-400 via-emerald-300 to-teal-400 bg-clip-text text-transparent">
        plane for MCP.
      </span>
    </h1>

    <p class="text-2xl text-zinc-300 mb-4">
      Hangar runs every MCP tool call through one deterministic policy path in Kubernetes: admission policy on each server, per-server egress rules, and an audit trail with identity attribution for every call.
    </p>

    <p class="text-lg text-zinc-500 max-w-xl mx-auto mb-10">
      Deterministic, not ML. MIT and self-hosted — no SaaS, ever.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <Button href={LINKS.ossQuickstart} variant="primary" withArrow>
        Install {VERSION_TAG}
      </Button>
      <Button href={LINKS.github} variant="secondary" external>
        <GithubIcon /> GitHub
      </Button>
    </div>

  </div>
</section>
