---
---

<section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="text-center mb-10">
        <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wider mb-3">
            How it works
        </h2>
        <p class="text-xl md:text-2xl font-bold text-zinc-100">
            One proxy between your agents and your MCP servers
        </p>
    </div>

    <!-- Architecture diagram -->
    <div class="relative p-8 rounded-2xl bg-zinc-900/30 border border-zinc-800/50">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-4">
            
            <!-- AI Agents -->
            <div class="flex-1 text-center">
                <div class="inline-flex flex-col items-center gap-3 p-5 rounded-xl bg-sky-500/5 border border-sky-500/15">
                    <div class="w-10 h-10 rounded-lg bg-sky-500/10 border border-sky-500/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 14.5M14.25 3.104c.251.023.501.05.75.082M19.8 14.5l-2.391 2.391m0 0a2.25 2.25 0 01-3.182 0l-2.391-2.391m7.964 0a2.25 2.25 0 00-3.182 0" />
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-zinc-200">AI Agents</span>
                    <span class="text-xs text-zinc-500">Claude, GPT, custom</span>
                </div>
            </div>

            <!-- Arrow 1 -->
            <div class="hidden md:flex flex-col items-center gap-1">
                <div class="w-16 h-px bg-gradient-to-r from-sky-500/40 to-emerald-500/40"></div>
                <span class="text-[10px] text-zinc-600 font-mono">MCP</span>
            </div>
            <div class="md:hidden w-px h-8 bg-gradient-to-b from-sky-500/40 to-emerald-500/40"></div>

            <!-- Hangar (center) -->
            <div class="flex-1 text-center">
                <div class="inline-flex flex-col items-center gap-3 p-6 rounded-xl bg-emerald-500/5 border border-emerald-500/20 shadow-lg shadow-emerald-500/5">
                    <div class="w-12 h-12 rounded-lg bg-emerald-500/15 border border-emerald-500/25 flex items-center justify-center">
                        <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                        </svg>
                    </div>
                    <span class="text-base font-semibold text-emerald-300">Hangar</span>
                    <!-- Mini capabilities -->
                    <div class="flex flex-wrap justify-center gap-1.5">
                        <span class="px-2 py-0.5 text-[10px] rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Auth</span>
                        <span class="px-2 py-0.5 text-[10px] rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Policy</span>
                        <span class="px-2 py-0.5 text-[10px] rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Logs</span>
                    </div>
                </div>
            </div>

            <!-- Arrow 2 -->
            <div class="hidden md:flex flex-col items-center gap-1">
                <div class="w-16 h-px bg-gradient-to-r from-emerald-500/40 to-zinc-500/40"></div>
                <span class="text-[10px] text-zinc-600 font-mono">MCP</span>
            </div>
            <div class="md:hidden w-px h-8 bg-gradient-to-b from-emerald-500/40 to-zinc-500/40"></div>

            <!-- MCP Servers -->
            <div class="flex-1 text-center">
                <div class="inline-flex flex-col items-center gap-3 p-5 rounded-xl bg-zinc-800/30 border border-zinc-700/40">
                    <div class="w-10 h-10 rounded-lg bg-zinc-700/30 border border-zinc-600/30 flex items-center justify-center">
                        <svg class="w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-zinc-200">MCP Servers</span>
                    <span class="text-xs text-zinc-500">DB, APIs, tools</span>
                </div>
            </div>
        </div>
    </div>
</section>
