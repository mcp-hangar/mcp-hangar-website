{
  "buildCommand": "pnpm install && pnpm --filter site build",
  "outputDirectory": "packages/site/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/install.sh",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs/blog/:path*",
      "destination": "/blog/:path*",
      "permanent": true
    },
    {
      "source": "/docs/cloud/:path*",
      "destination": "/docs/:path*",
      "permanent": true
    },
    {
      "source": "/plans",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/waitlist",
      "destination": "/",
      "permanent": true
    }
  ]
}
