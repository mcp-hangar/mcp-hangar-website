{
  "name": "mcp-hangar-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Official website for MCP Hangar - The MCP Control Plane",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-hangar/mcp-hangar-website.git"
  },
  "homepage": "https://mcp-hangar.io",
  "bugs": {
    "url": "https://github.com/mcp-hangar/mcp-hangar-website/issues"
  },
  "license": "MIT",
  "author": "mcp-hangar contributors",
  "scripts": {
    "dev": "vite",
    "dev:docs": "npm run fetch-docs && vitepress dev docs",
    "build": "npm run build:site && npm run build:prerender && npm run build:docs && npm run build:merge && npm run build:sitemap",
    "build:site": "tsc -b && vite build",
    "build:prerender": "node scripts/prerender.mjs",
    "build:docs": "npm run fetch-docs && vitepress build docs",
    "build:merge": "cp -r docs/.vitepress/dist dist/docs",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "preview:docs": "vitepress preview docs",
    "lint": "eslint .",
    "fetch-docs": "node scripts/sync-docs.mjs",
    "clean-docs": "node scripts/sync-docs.mjs --clean",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.2",
    "@vercel/node": "^5.7.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}
